{
	"name": "Bog Music",
	"short_name": "Bog Music",
	"description": "Music player with offline cache and Giper Baza sync",
	"id": "bog_music_app",
	"start_url": ".",
	"display": "standalone",
	"background_color": "#000000",
	"theme_color": "#000000",
	"manifest_version": 3,
	"version": "1.2.2.1",
	"action": {
		"default_title": "Bog Music",
		"default_icon": "bog/music/app/favicon.svg"
	},
	"background": {
		"service_worker": "bog/music/ext/background.js"
	},
	"permissions": [
		"storage",
		"cookies",
		"offscreen",
		"tabs"
	],
	"host_permissions": [
		"https://api.vk.com/*",
		"https://*.vk.com/*",
		"https://vk.com/*",
		"https://*.vk.ru/*",
		"https://vk.ru/*",
		"https://*.userapi.com/*",
		"https://baza.87.120.36.150.ip.giper.dev/*",
		"wss://baza.87.120.36.150.ip.giper.dev/*"
	],
	"icons": [
		{
			"src": "bog/music/app/favicon.svg",
			"sizes": "any",
			"type": "image/svg+xml",
			"purpose": "any"
		},
		{
			"src": "bog/music/app/favicon.svg",
			"sizes": "any",
			"type": "image/svg+xml",
			"purpose": "maskable"
		}
	],
	"content_scripts": [
		{
			"matches": [
				"*://*.vk.com/*",
				"*://vk.com/*",
				"*://*.vk.ru/*",
				"*://vk.ru/*"
			],
			"js": [
				"bog/music/ext/content.js"
			],
			"run_at": "document_start",
			"all_frames": false
		}
	],
	"web_accessible_resources": [
		{
			"resources": [
				"bog/music/ext/inject.js"
			],
			"matches": [
				"*://*.vk.com/*",
				"*://vk.com/*",
				"*://*.vk.ru/*",
				"*://vk.ru/*"
			]
		}
	]
}